# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=agent-ops-api
APP_VERSION=1.0.0
APP_ENV=local           # local | dev | prod
DEBUG=true
LOG_LEVEL=DEBUG

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default     # Local named profile; omit in prod (use IAM role)
# AWS_ACCESS_KEY_ID=     # Not recommended – prefer profiles or IAM roles
# AWS_SECRET_ACCESS_KEY=

# ── Bedrock ───────────────────────────────────────────────────────────────────
# Optional fallback IAM role ARN for agents that don't declare their own
# spec.k8s.roleArn in the YAML definition. Prefer per-agent roles.
DEFAULT_BEDROCK_AGENT_ROLE_ARN=

# ── Agent definitions ─────────────────────────────────────────────────────────
AGENT_DEFINITION_DIR=agent-definition

