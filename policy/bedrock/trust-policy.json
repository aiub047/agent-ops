{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowEKSIRSA",
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::314630006302:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/BC7A6355A235E9CDB9E1FFC634D891E6"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "oidc.eks.us-east-1.amazonaws.com/id/BC7A6355A235E9CDB9E1FFC634D891E6:aud": "sts.amazonaws.com",
          "oidc.eks.us-east-1.amazonaws.com/id/BC7A6355A235E9CDB9E1FFC634D891E6:sub": "system:serviceaccount:default:bedrock-sa"
        }
      }
    },
    {
      "Sid": "AllowBedrockAgentExecution",
      "Effect": "Allow",
      "Principal": {
        "Service": "bedrock.amazonaws.com"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "314630006302"
        }
      }
    }
  ]
}
